# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
# Local: mongodb://localhost:27017/homeopathy_db
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/homeopathy_db
MONGO_URI=mongodb://localhost:27017/homeopathy_db

# Google Gemini AI
# Get key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_actual_gemini_api_key_here

# Gemini Model (optional, defaults to gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash
